<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.hi.practice.dao.UserDao">

	<select id="findByUsername" parameterType="String" resultType="map">
        SELECT * FROM users 
        WHERE username = #{username}
    </select>
    
    <insert id="insertUser" parameterType="kr.hi.practice.domain.UserDTO">
        INSERT INTO users (username, password, text, email, gender)
        VALUES (#{username}, #{password}, #{text}, #{email}, #{gender})
    </insert>

</mapper>